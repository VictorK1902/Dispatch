{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "clean (function)",
			"command": "dotnet",
			"args": [
				"clean",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"type": "process",
			"problemMatcher": "$msCompile",
			"options": {
				"cwd": "${workspaceFolder}/Worker"
			}
		},
		{
			"label": "build (function)",
			"command": "dotnet",
			"args": [
				"build",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"type": "process",
			"dependsOn": "clean (function)",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$msCompile",
			"options": {
				"cwd": "${workspaceFolder}/Worker"
			}
		},
		{
			"label": "clean release (function)",
			"command": "dotnet",
			"args": [
				"clean",
				"--configuration",
				"Release",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"type": "process",
			"problemMatcher": "$msCompile",
			"options": {
				"cwd": "${workspaceFolder}/Worker"
			}
		},
		{
			"label": "publish (function)",
			"command": "dotnet",
			"args": [
				"publish",
				"--configuration",
				"Release",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"type": "process",
			"dependsOn": "clean release (function)",
			"problemMatcher": "$msCompile",
			"options": {
				"cwd": "${workspaceFolder}/Worker"
			}
		},
		{
			"label": "run (function)",
			"type": "func",
			"dependsOn": "build (function)",
			"options": {
				"cwd": "${workspaceFolder}/Worker/bin/Debug/net10.0"
			},
			"command": "host start",
			"isBackground": true,
			"problemMatcher": "$func-dotnet-watch"
		},
		{
			"label": "build (api)",
			"command": "dotnet",
			"args": [
				"build",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"type": "process",
			"problemMatcher": "$msCompile",
			"options": {
				"cwd": "${workspaceFolder}/Api"
			}
		},
		{
			"label": "run (api)",
			"command": "dotnet",
			"args": [
				"run"
			],
			"type": "process",
			"dependsOn": "build (api)",
			"isBackground": true,
			"problemMatcher": [],
			"options": {
				"cwd": "${workspaceFolder}/Api",
				"env": {
					"PATH": "/opt/homebrew/bin:${env:PATH}"
				}
			}
		}
	]
}