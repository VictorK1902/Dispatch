{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build (api)",
			"command": "dotnet",
			"args": [
				"build",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"type": "process",
			"problemMatcher": "$msCompile",
			"options": {
				"cwd": "${workspaceFolder}/Api"
			}
		},
		{
			"label": "run (api)",
			"command": "dotnet",
			"args": [
				"run",
				"--launch-profile",
				"https"
			],
			"type": "process",
			"dependsOn": "build (api)",
			"isBackground": true,
			"problemMatcher": [],
			"options": {
				"cwd": "${workspaceFolder}/Api",
				"env": {
					"PATH": "/opt/homebrew/bin:${env:PATH}"
				}
			}
		},
		{
			"label": "clean release (api)",
			"command": "dotnet",
			"args": [
				"clean",
				"--configuration",
				"Release",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"type": "process",
			"problemMatcher": "$msCompile",
			"options": {
				"cwd": "${workspaceFolder}/Api"
			}
		},
		{
			"label": "publish (api)",
			"command": "dotnet",
			"args": [
				"publish",
				"--configuration",
				"Release",
				"--output",
				"./publish",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"type": "process",
			"dependsOn": "clean release (api)",
			"problemMatcher": "$msCompile",
			"options": {
				"cwd": "${workspaceFolder}/Api"
			}
		},
		{
			"label": "zip (api)",
			"type": "shell",
			"command": "cd publish && zip -r ../publish.zip . && cd ..",
			"dependsOn": "publish (api)",
			"problemMatcher": [],
			"options": {
				"cwd": "${workspaceFolder}/Api"
			}
		},
		{
			"label": "deploy (api)",
			"command": "az",
			"args": [
				"webapp",
				"deploy",
				"--resource-group",
				"rg-dispatch",
				"--name",
				"api-dispatch",
				"--src-path",
				"publish.zip",
				"--type",
				"zip"
			],
			"type": "process",
			"dependsOn": "zip (api)",
			"problemMatcher": [],
			"options": {
				"cwd": "${workspaceFolder}/Api"
			}
		},
		{
			"label": "clean (functions)",
			"command": "dotnet",
			"args": [
				"clean",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"type": "process",
			"problemMatcher": "$msCompile",
			"options": {
				"cwd": "${workspaceFolder}/Worker"
			}
		},
		{
			"label": "build (functions)",
			"command": "dotnet",
			"args": [
				"build",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"type": "process",
			"dependsOn": "clean (functions)",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$msCompile",
			"options": {
				"cwd": "${workspaceFolder}/Worker"
			}
		},
		{
			"label": "clean release (functions)",
			"command": "dotnet",
			"args": [
				"clean",
				"--configuration",
				"Release",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"type": "process",
			"problemMatcher": "$msCompile",
			"options": {
				"cwd": "${workspaceFolder}/Worker"
			}
		},
		{
			"label": "publish (functions)",
			"command": "dotnet",
			"args": [
				"publish",
				"--configuration",
				"Release",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"type": "process",
			"dependsOn": "clean release (functions)",
			"problemMatcher": "$msCompile",
			"options": {
				"cwd": "${workspaceFolder}/Worker"
			}
		},
		{
			"label": "deploy (functions)",
			"command": "func",
			"args": [
				"azure",
				"functionapp",
				"publish",
				"func-dispatch-worker"
			],
			"type": "process",
			"dependsOn": "publish (functions)",
			"problemMatcher": [],
			"options": {
				"cwd": "${workspaceFolder}/Worker"
			}
		},
		{
			"label": "run (functions)",
			"type": "func",
			"dependsOn": "build (functions)",
			"options": {
				"cwd": "${workspaceFolder}/Worker/bin/Debug/net10.0"
			},
			"command": "host start",
			"isBackground": true,
			"problemMatcher": "$func-dotnet-watch"
		}
	]
}